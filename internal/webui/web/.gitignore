# Generated TypeScript API client. The contract is openapi.json; the
# file under src/lib/ is regenerated by `npm run gen:client` (chained
# from `prebuild` so any `npm run build` produces a fresh copy).
src/lib/api-client.ts

# Vite build output. The bundle is a build artefact regenerated by
# `make webui` (or `npm run build`); only the stub index.html is
# committed so the //go:embed in internal/webui/embed.go succeeds on
# a fresh clone before the SPA is built.
/dist/*
!/dist/index.html
